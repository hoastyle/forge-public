# Repo-local runtime config for Forge.
# Copy this file to .env and fill in the values you actually use.

FORGE_KNOWLEDGE_CLIENT=litellm
FORGE_INSIGHT_CLIENT=litellm
LITELLM_LOCAL_MODEL_COST_MAP=true

# Default runtime profiles use OpenAI-compatible models / relays.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1

# Uncomment only if you switch runtime profiles to anthropic/*.
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://your-anthropic-compatible-endpoint

# Public CLI / service connection defaults.
# FORGE_SERVER=http://127.0.0.1:8000
# FORGE_TOKEN=

# Self-hosted service defaults.
# FORGE_SERVER_TOKEN=change-me
# FORGE_SERVICE_REPO_ROOT=/var/lib/forge/repo
# FORGE_STATE_ROOT=/var/lib/forge/state
